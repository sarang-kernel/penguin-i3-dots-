    // kb-accept-custom: "Control+Return";
    // kb-cancel: "Escape";
    //
    /* ---------- Mode complete (cycle modes) ---------- */
    // kb-mode-complete: "Control+l";

configuration {
    modi: "drun,run,window,clipboard:greenclip print";
    terminal: "kitty";
    icon-theme: "Papirus";
    show-icons: true;
    drun-display-format: "{icon} {name}";
    location: 0;
    hide-scrollbar: true;
    disable-history: false;
    sidebar-mode: false;
    display-drun: "";
    display-run: "";
    display-window: "";
    display-clipboard: "";
}

/* Ensure icons are not hidden by the theme */
element-icon {
    size: 24px;
}


/* ---------- Theme ---------- */
@theme "catppuccin-mocha"

