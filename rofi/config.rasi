//
// @theme "catppuccin-mocha"
//

// | Action          | Keys        |
// | --------------- | ----------- |
// | Move up/down    | `j` / `k`   |
// | Move left/right | `h` / `l`   |
// | Start of line   | Ctrl+A      |
// | End of line     | Ctrl+E      |
// | Delete to start | Ctrl+U      |
// | Delete to end   | Ctrl+K      |
// | Delete word     | Ctrl+W      |
// | Accept          | Enter       |
// | Alt accept      | Shift+Enter |
// | Custom action   | Ctrl+Enter  |
// | Cancel          | Esc         |
// | Cycle modes     | Ctrl+L      |
//

   /* ---------- Vim-like Navigation ---------- */
    // kb-row-up: "k,Up";
    // kb-row-down: "j,Down";
    // kb-row-left: "h,Left";
    // kb-row-right: "l,Right";
    //
    // /* ---------- Editing (terminal/vim friendly) ---------- */
    // kb-move-front: "Control+a";
    // kb-move-end: "Control+e";
    // kb-remove-to-sol: "Control+u";
    // kb-remove-to-eol: "Control+k";
    // kb-remove-word-back: "Control+w";
    //
    // /* ---------- Accept / Cancel ---------- */
    // kb-accept-entry: "Return";
